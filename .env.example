# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (para login e Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Service Account (para Drive)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Anthropic (Claude) — usado pelas abas de IA
ANTHROPIC_API_KEY=

# Remetente comercial para disparos (Prospecção / CCO)
COMERCIAL_FROM_EMAIL=comercial@nexcoworking.com.br
COMERCIAL_FROM_NAME=Nex Coworking

# RD Station CRM — token de API (em Configurações > Integrações > API no RD CRM)
RDCRM_TOKEN=

# RD Conversas — API REST v2 (Tallos). Token gerado no painel do RD Conversas.
# Usado para exportar o histórico de conversas para avaliação automática.
RD_CONVERSAS_TOKEN=
# Base opcional (padrão: https://api.tallos.com.br/v2)
RD_CONVERSAS_API_URL=https://api.tallos.com.br/v2

# Segredo do cron (usado pelo GitHub Actions para chamar /api/cron/avaliacao-conversas)
CRON_SECRET=
